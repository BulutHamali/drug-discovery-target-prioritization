nextflow.enable.dsl = 2

// ── default parameters ────────────────────────────────────────────────────────
// All paths are relative to the pipeline/ directory so the pipeline can be
// run from any working directory with: nextflow run pipeline/main.nf
params {
    // Input VCF: defaults to the chr22 subset cached by data/fetch_1000genomes.sh
    vcf     = "${projectDir}/../data/cache/1000genomes/chr22.vcf.gz"

    // Chromosome to process. Change this (and the vcf path) to scale up.
    chrom   = "22"

    // Optional: path to a file listing sample IDs to subset (one per line).
    // Leave empty to use all samples in the VCF.
    samples = ""

    // Reference files for bcftools csq. Fetched by data/fetch_ref.sh.
    gff   = "${projectDir}/../data/cache/ref/chr22.gff3.gz"
    fasta = "${projectDir}/../data/cache/ref/chr22.fa"

    // Rare-variant AF ceiling. Variants with AF >= af_max are excluded.
    af_max = 0.01

    // Output directory for the final Parquet feature table.
    outdir = "${projectDir}/../results"

    // S3 bucket for awsbatch workDir.
    // Set to the value of: terraform -chdir=terraform output -raw work_bucket_name
    // Or: export NXF_WORK="s3://<bucket>/work" before running with -profile awsbatch
    work_bucket = ""

    // ECR repository URL for the BURDEN/COLLECT image, awsbatch profile only.
    // Set to the value of: terraform -chdir=terraform output -raw ecr_repository_url
    // e.g. --ecr_repository_url 020529562965.dkr.ecr.us-east-1.amazonaws.com/drug-target-burden
    ecr_repository_url = ""

    // ECR repository URL for the PREPARE/ANNOTATE image (bcftools + awscli,
    // see pipeline/docker/bcftools-batch/Dockerfile), awsbatch profile only.
    // Set to the value of: terraform -chdir=terraform output -raw ecr_bcftools_batch_repository_url
    ecr_bcftools_batch_repository_url = ""

    // IAM job role ARN for Batch jobs, awsbatch profile only. Without this,
    // Nextflow's dynamically-registered job definitions have no jobRoleArn,
    // so containers fall back to the EC2 instance role, which only has
    // AmazonEC2ContainerServiceforEC2Role (no S3 permissions). The task
    // then fails staging .command.run / .command.log with 403/AccessDenied.
    // Set to the value of: terraform -chdir=terraform output -raw batch_job_role_arn
    batch_job_role_arn = ""
}

// ── containers ────────────────────────────────────────────────────────────────
// PREPARE and ANNOTATE use the bcftools biocontainer (includes samtools/htslib).
// BURDEN and COLLECT use a minimal Python image with pyarrow.
// Build the Python image once before running locally:
//   docker build -t drug-target-burden:1.0 pipeline/docker/
process {
    withName: 'PREPARE|ANNOTATE' {
        container = 'quay.io/biocontainers/bcftools:1.18--h8b25389_0'
    }
    withName: 'BURDEN|COLLECT' {
        container = 'drug-target-burden:1.0'
    }
}

// ── profiles ──────────────────────────────────────────────────────────────────

profiles {

    local {
        // Run entirely on the local machine with Docker.
        // --platform linux/amd64 is required on Apple Silicon.
        process.executor  = 'local'
        docker.enabled    = true
        docker.runOptions = '--platform linux/amd64'
    }

    awsbatch {
        // Run on AWS Batch in us-east-1.
        // Before running, set your work directory:
        //   export NXF_WORK="s3://$(terraform -chdir=terraform output -raw work_bucket_name)/work"
        // Then:
        //   nextflow run pipeline/main.nf -profile awsbatch \
        //     --ecr_repository_url $(terraform -chdir=terraform output -raw ecr_repository_url) \
        //     --ecr_bcftools_batch_repository_url $(terraform -chdir=terraform output -raw ecr_bcftools_batch_repository_url) \
        //     --batch_job_role_arn $(terraform -chdir=terraform output -raw batch_job_role_arn)
        process.executor = 'awsbatch'
        process.queue    = 'drug-discovery-target-prioritization-queue'
        aws.region       = 'us-east-1'
        aws.batch.jobRole = params.batch_job_role_arn
        docker.enabled   = true
        // workDir is picked up from NXF_WORK env var (preferred) or set here:
        // workDir = "s3://${params.work_bucket}/work"

        // Both container groups use ECR-hosted images here, not the bare
        // local tags the `local` profile above uses. AWS Batch pulls from a
        // registry, not the local Docker daemon; an unqualified image name
        // resolves against Docker Hub by default, where these private
        // images do not exist. Both also need the AWS CLI baked in:
        // Nextflow's awsbatch executor runs `aws s3 cp` INSIDE the
        // container to stage .command.run and push outputs, so the plain
        // quay.io/biocontainers/bcftools image the `local` profile uses
        // unchanged would fail here too, hence the separate
        // bcftools-batch image (pipeline/docker/bcftools-batch/Dockerfile)
        // instead of reusing the same container reference.
        process {
            withName: 'PREPARE|ANNOTATE' {
                container = "${params.ecr_bcftools_batch_repository_url}:1.18"
            }
            withName: 'BURDEN|COLLECT' {
                container = "${params.ecr_repository_url}:1.0"
            }
        }
    }

}
