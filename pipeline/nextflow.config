nextflow.enable.dsl = 2

// ── default parameters ────────────────────────────────────────────────────────
// All paths are relative to the pipeline/ directory so the pipeline can be
// run from any working directory with: nextflow run pipeline/main.nf
params {
    // Input VCF: defaults to the chr22 subset cached by data/fetch_1000genomes.sh
    vcf     = "${projectDir}/../data/cache/1000genomes/chr22.vcf.gz"

    // Chromosome to process. Change this (and the vcf path) to scale up.
    chrom   = "22"

    // Optional: path to a file listing sample IDs to subset (one per line).
    // Leave empty to use all samples in the VCF.
    samples = ""

    // Reference files for bcftools csq. Fetched by data/fetch_ref.sh.
    gff   = "${projectDir}/../data/cache/ref/chr22.gff3.gz"
    fasta = "${projectDir}/../data/cache/ref/chr22.fa"

    // Rare-variant AF ceiling. Variants with AF >= af_max are excluded.
    af_max = 0.01

    // Output directory for the final Parquet feature table.
    outdir = "${projectDir}/../results"

    // S3 bucket for awsbatch workDir.
    // Set to the value of: terraform -chdir=terraform output -raw work_bucket_name
    // Or: export NXF_WORK="s3://<bucket>/work" before running with -profile awsbatch
    work_bucket = ""
}

// ── containers ────────────────────────────────────────────────────────────────
// PREPARE and ANNOTATE use the bcftools biocontainer (includes samtools/htslib).
// BURDEN and COLLECT use a minimal Python image with pyarrow.
// Build the Python image once before running locally:
//   docker build -t drug-target-burden:1.0 pipeline/docker/
process {
    withName: 'PREPARE|ANNOTATE' {
        container = 'quay.io/biocontainers/bcftools:1.18--h8b25389_0'
    }
    withName: 'BURDEN|COLLECT' {
        container = 'drug-target-burden:1.0'
    }
}

// ── profiles ──────────────────────────────────────────────────────────────────

profiles {

    local {
        // Run entirely on the local machine with Docker.
        // --platform linux/amd64 is required on Apple Silicon.
        process.executor  = 'local'
        docker.enabled    = true
        docker.runOptions = '--platform linux/amd64'
    }

    awsbatch {
        // Run on AWS Batch in us-east-1.
        // Before running, set your work directory:
        //   export NXF_WORK="s3://$(terraform -chdir=terraform output -raw work_bucket_name)/work"
        // Then:
        //   nextflow run pipeline/main.nf -profile awsbatch
        process.executor = 'awsbatch'
        process.queue    = 'drug-discovery-target-prioritization-queue'
        aws.region       = 'us-east-1'
        docker.enabled   = true
        // workDir is picked up from NXF_WORK env var (preferred) or set here:
        // workDir = "s3://${params.work_bucket}/work"
    }

}
